{

  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/info/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        },
        "Filter": [
          {
            "Name": "ByIncludingOnly",
            "Args": {
              "expression": "@l = 'Information'"
            }
          }
        ]
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/warn-error/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        },
        "Filter": [
          {
            "Name": "ByIncludingOnly",
            "Args": {
              "expression": "@l in ['Warning','Error','Fatal']"
            }
          }
        ]
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    //  "DefaultConnection": "Server=DESKTOP-G9UCAB0\\SQLEXPRESS;Database=db_user;Trusted_Connection=True;TrustServerCertificate=True;",
    "DefaultConnection": "Server=43.254.41.245,1433;Database=TravelPlatform_Accommodation;User Id=sa;Password=QiqrplSJZ9Vsa;TrustServerCertificate=True;"
  },

  "Jwt": {
    "Key": "soyherntravelSouthern12344556547", //Generate random String from https://www.random.org/strings
    "Issuer": "http://localhost:28747/", //Project Property-> Debug-> IIS-->App URL (you can local host url as well)
    "Audience": "http://localhost:28747/",
    "ExpireMinutes": 60
  }

}
